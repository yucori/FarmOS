# ── 데이터베이스 ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/farmos

# ── 보안 및 인증 ────────────────────────────────────────────────────────
# FarmOS 백엔드와 반드시 동일해야 합니다 (공유 JWT 인증)
JWT_SECRET_KEY=your_jwt_secret_key_here

# ── 외부 API 연동 ───────────────────────────────────────────────────────
FARMOS_API_URL=http://localhost:8000/api/v1
# 공공데이터포털 - 한국천문연구원 특일 정보제공 서비스
# https://www.data.go.kr/data/15012690/openapi.do
ANNIVERSARY_API_KEY=your_anniversary_api_key_here

# ── CORS ────────────────────────────────────────────────────────────────
ALLOW_ORIGINS=["http://localhost:5173", "http://localhost:5174", "http://localhost:5175"]

# ── 임베딩 ──────────────────────────────────────────────────────────────
# ⚠️  시딩(seed_rag.py)과 서버 실행 시 반드시 동일한 provider + model을 사용하세요.
#     바꾸면 re-seed + distance_threshold 재측정 필요.
#
# [기본] sentence_transformers — 로컬 실행, API 키·서버 불필요
#   첫 실행 시 HuggingFace에서 ~2.2GB 자동 다운로드
EMBED_PROVIDER=sentence_transformers
EMBED_MODEL=BAAI/bge-m3
#
# [대안] openrouter — LITELLM_API_KEY 자동 재사용
# EMBED_PROVIDER=openrouter
# EMBED_MODEL=openai/text-embedding-3-small
#
# [대안] openai — EMBED_API_KEY 별도 필요
# EMBED_PROVIDER=openai
# EMBED_MODEL=text-embedding-3-small
# EMBED_API_KEY=sk-...

# ── LLM (LiteLLM 프록시) ────────────────────────────────────────────────
# Primary(챗봇 에이전트 도구 선택·응답 생성) + Utility(리포트/비용분류) 공용
# LiteLLM 인스턴스의 /v1/models 에서 사용 가능한 모델 목록 확인
LITELLM_URL=https://your-litellm-instance/v1
LITELLM_API_KEY=sk-...
LITELLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openrouter

# ── Fallback LLM (Anthropic Claude) — 비워두면 폴백 비활성화 ────────────
ANTHROPIC_API_KEY=
CLAUDE_FALLBACK_MODEL=claude-haiku-4-5

# ── 에이전트 ────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10

# ── 재랭킹 (Cross-Encoder) ───────────────────────────────────────────────
# BM25+Dense 하이브리드 검색 후보를 정밀 재정렬.
# 비워두면 재랭킹 비활성화. 첫 실행 시 ~2.27GB 자동 다운로드.
RERANKER_MODEL=dragonkue/bge-reranker-v2-m3-ko

# ── LangSmith 트레이싱 (선택) ────────────────────────────────────────────
# smith.langchain.com → 프로젝트 생성 후 API 키 발급
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=farmos-shoppingmall-chatbot

# ── 정책 문서 폴더 (기본값: shopping_mall/backend/ai/docs/) ──────────────
# POLICY_DOCS_DIR=/path/to/your/docs
