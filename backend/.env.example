# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farmos

# CORS 허용 도메인 (프론트엔드 → 백엔드 API 호출 허용)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 센서 임계값
SOIL_MOISTURE_LOW=55.0
SOIL_MOISTURE_HIGH=70.0

# OpenRouter LLM API (https://openrouter.ai/keys 에서 발급)
# 영농일지 음성입력 STT 파싱 및 일일요약에 사용
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq Whisper API (https://console.groq.com/keys 에서 발급)
# 영농일지 서버사이드 음성 전사(STT)에 사용
GROQ_API_KEY=your_groq_api_key_here
GROQ_STT_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_STT_MODEL=whisper-large-v3

# 식품안전나라 공공데이터 API (https://www.foodsafetykorea.go.kr/ 에서 발급)
# 식품의약품안전처 공공데이터활용 — 농약 등록정보(I1910) 조회에 사용
# 회원가입 후 Open-API 이용신청 → 인증키 발급
FOOD_SAFETY_API_KEY=your_food_safety_api_key_here

# KAMIS 농산물 시세 API
KAMIS_API_KEY=
KAMIS_CERT_ID=
