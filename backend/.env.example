# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farmos

# JWT 키 (FarmOS 백엔드와 반드시 동일해야 함 — 공유 인증)
JWT_SECRET_KEY=your_jwt_secret_key_here

# CORS 허용 도메인 (프론트엔드 → 백엔드 API 호출 허용)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# 센서 임계값
SOIL_MOISTURE_LOW=55.0
SOIL_MOISTURE_HIGH=70.0

# OpenRouter LLM API (litellm 에서 발급)
# 영농일지 음성입력 STT 파싱 및 일일요약에 사용
# 해충 진단 통합 RAG 챗봇에 사용
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq Whisper API (https://console.groq.com/keys 에서 발급)
# 영농일지 서버사이드 음성 전사(STT)에 사용
GROQ_API_KEY=your_groq_api_key_here
GROQ_STT_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_STT_MODEL=whisper-large-v3

# 식품안전나라 공공데이터 API (https://www.foodsafetykorea.go.kr/ 에서 발급)
# 식품의약품안전처 공공데이터활용 — 농약 등록정보(I1910) 조회에 사용
# 회원가입 후 Open-API 이용신청 → 인증키 발급
FOOD_SAFETY_API_KEY=your_food_safety_api_key_here

# KAMIS 농산물 시세 API
KAMIS_API_KEY=
KAMIS_CERT_ID=

# 농업/기상 공공데이터 API
# 기상청 단기예보 서비스 (지역 날씨 오케스트레이션용), 디코딩 키
WEATHER_API_KEY=your_weather_api_key_here

# 국가농작물병해충관리시스템(NCPMS) API
NCPMS_API_KEY=your_ncpms_api_key_here

# 농촌진흥청 농약안전정보시스템 API
PESTICIDE_API_KEY=your_pesticide_api_key_here

# 해충 진단후 챗봇 모델
OPENROUTER_PEST_RAG_MODEL=gpt-5-nano

# 오픈라우터 URL
# OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_URL=https://litellm.lilpa.moe/v1