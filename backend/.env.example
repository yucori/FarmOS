# ── 기본 설정 ──────────────────────────────────────────────────────────
PROJECT_NAME=FarmOS
API_V1_PREFIX=/api/v1
APP_TIMEZONE=Asia/Seoul

# ── 데이터베이스 ────────────────────────────────────────────────────────
# 데이터베이스 (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/farmos
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# 벡터 데이터베이스 (ChromaDB)
CHROMA_DB_PATH="./chroma_data"

# ── 보안 및 인증 ────────────────────────────────────────────────────────
# JWT 시크릿 키 (FarmOS-ShoppingMall 공유 인증)
JWT_SECRET_KEY=

# CORS 허용 도메인 (JSON 배열 형식)
# 프론트엔드 → 백엔드 API 호출 허용
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:3000","http://iot.lilpa.moe"]

# ── 외부 API (공공데이터/지도) ──────────────────────────────────────────
# 기상청 API (단기예보 등)
# 기상청 단기예보 서비스 (지역 날씨 오케스트레이션용)
KMA_DECODING_KEY=

# 국가농작물병해충관리시스템 (NCPMS)
NCPMS_API_KEY=

# 농약안전정보시스템 
PESTICIDE_API_KEY=

# 식품안전나라
# 식품의약품안전처 공공데이터활용 — 농약 등록정보(I1910) 조회에 사용
# 회원가입 후 Open-API 이용신청 → 인증키 발급
FOOD_SAFETY_API_KEY=

# 농산물유통정보 (KAMIS)
KAMIS_API_KEY=
KAMIS_CERT_ID=

# 카카오 REST API (위도 및 경도 변환)
KAKAO_REST_API_KEY=

# ── LLM & AI 서비스 ──────────────────────────────────────────────────────
# LiteLLM 프록시 / OpenRouter
# LiteLLM 사용 모델 목록 -> gpt-5-nano, gpt-5-mini, gpt-oss-20b, gemma-4-31b-it
LITELLM_API_KEY=
LITELLM_URL=https://litellm.lilpa.moe/v1
LITELLM_MODEL=gpt-oss-20b

# Groq (Whisper STT)
# 영농일지 서버사이드 음성 전사(STT)에 사용
GROQ_API_KEY=
GROQ_STT_URL=https://api.groq.com/openai/v1/audio/transcriptions
GROQ_STT_MODEL=whisper-large-v3

# 리뷰 분석 및 기타 LLM 설정
LLM_PROVIDER=litellm
LLM_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REMOTE_URL=

EMBED_MODEL=voyage-3.5
EMBED_DIM=1024

# LLM 리즈닝 강도 (GPT-5 계열 reasoning 모델용)
# minimal | low | medium | high  또는 "none"(파라미터 미전송)
# non-reasoning 모델(gemma, gpt-oss 등)은 무시됨
LLM_REASONING_EFFORT=minimal

# Review Embedding (LiteLLM 프록시 경유, VoyageAI 등)
REVIEW_ANALYSIS_BATCH_SIZE=40
REVIEW_ANALYSIS_MAX_RETRIES=2

# ── AI Agent (IoT 제어) ──────────────────────────────────────────────────
AI_AGENT_MODEL=openai/gpt-5-mini
AI_AGENT_LLM_INTERVAL=300
AI_AGENT_RULE_INTERVAL=30

# IoT Relay Server Bridge
# AI Agent Action History Bridge (Relay → FarmOS 미러)
# Relay 와 공유하는 시크릿. 비워두면 AI_AGENT_BRIDGE_ENABLED=true 라도 안전 비활성화된다.
# 운영 환경에서는 절대 코드에 하드코딩하지 말고 반드시 환경변수/.env 로만 주입한다.
# 실제 키는 반드시 .env / 환경변수(IOT_RELAY_API_KEY) 로 주입한다.
# 빈 문자열이면 AI_AGENT_BRIDGE_ENABLED=True 라도 Bridge 는 안전하게 비활성화된다.
IOT_RELAY_BASE_URL=http://localhost:9000
IOT_RELAY_API_KEY=
AI_AGENT_BRIDGE_ENABLED=false
AI_AGENT_MIRROR_TTL_DAYS=30
AI_AGENT_BACKFILL_PAGE_SIZE=200

# 센서 임계값
SOIL_MOISTURE_LOW=55.0
SOIL_MOISTURE_HIGH=70.0

# ── 기타 설정 ────────────────────────────────────────────────────────────
# 농장 위치 (기상청 격자좌표 기본값)
FARM_NX=84
FARM_NY=106

# 한글 폰트 (PDF 생성용) — 저장소에 번들된 Pretendard(SIL OFL 1.1) 기본 사용.
# 시스템 폰트 사용하려면 .env에서 절대 경로로 오버라이드 가능.
FONT_PATH=
FONT_BOLD_PATH=

# ── 공익직불 RAG (정부 지원금 매칭) ─────────────────────────────────
# Upstage API Key (https://console.upstage.ai 에서 발급)
# - Document Parse: PDF/HWP → Markdown 변환 (한국 정부 문서 특화)
# - Solar Embedding: 한국어 최적화 asymmetric embedding (passage/query)
UPSTAGE_API_KEY=your_upstage_api_key_here

# 공익직불 모듈 LLM — 위 LITELLM_URL / LITELLM_API_KEY 재사용, 모델만 오버라이드
SUBSIDY_LLM_MODEL=google/gemma-4-31b-it
SUBSIDY_RERANKER_MODEL=dragonkue/bge-reranker-v2-m3-ko
SUBSIDY_PDF_PATH=data/gov/2026_공익직불_시행지침.pdf
SUBSIDY_MARKDOWN_CACHE_PATH=data/gov/2026_공익직불_시행지침.md
