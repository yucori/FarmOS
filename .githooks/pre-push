#!/bin/bash

REMOTE_URL=$(git remote get-url origin 2>/dev/null || echo "없음")
CURRENT_BRANCH=$(git branch --show-current)

echo ""
echo "⚠️  잠깐! push 전에 생각했나요?"
echo "-----------------------------"
echo "📡 Remote 주소 : $REMOTE_URL"
echo "🌿 현재 Branch : $CURRENT_BRANCH"
echo "☠️ 잘못된 push는 다른 팀원의 작업을 방해합니다."
echo "-----------------------------"
echo ""

read -p "정말 push 하시겠습니까? (y/N): " confirm

if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
  echo "❌ push가 취소되었습니다."
  exit 1
fi

exit 0
